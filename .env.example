# ============================================================================
# Voice AI Observability Copilot — environment configuration
# Copy to `.env` and fill in. Every key maps to a `runtimeConfig` value in
# nuxt.config.ts; unset keys fall back to the defaults shown here.
# ============================================================================

# ----------------------------------------------------------------------------
# LLM analysis engine (pluggable provider)
# ----------------------------------------------------------------------------
# Which provider the analysis engine uses:
#   ollama    -> local Ollama server (default, no API key, fully offline)
#   anthropic -> Claude via @anthropic-ai/sdk (requires ANTHROPIC_API_KEY)
#   mock      -> deterministic heuristic analyzer (no model, great for demos/CI)
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama). Ollama must be running and the model
# pulled: `ollama pull qwen2.5:14b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Anthropic / Claude (used when LLM_PROVIDER=anthropic). Leave blank otherwise.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ----------------------------------------------------------------------------
# HighLevel (GoHighLevel) integration
# ----------------------------------------------------------------------------
# Private Integration Token minted in your sandbox sub-account. Needs the
# voice-ai-dashboard.readonly scope (+ agents read). Used by /api/sync and the
# PIT-authenticated GHL client. Leave blank to run on seeded data only.
GHL_PIT_TOKEN=

# GHL REST API base. The LeadConnector host is the marketplace default.
GHL_API_BASE=https://services.leadconnectorhq.com

# Shared secret configured on the Custom Page / Menu Link. Used to AES-decrypt
# the signed user-context payload posted to the iframe (see /api/context).
GHL_SHARED_SECRET=
